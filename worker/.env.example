# Campaign Factory worker — environment template.
# Copy to worker/.env for local runs. The migration runner and worker also read
# ../web/.env.local as a fallback (worker/.env values take precedence).

# --- Database ---------------------------------------------------------------
# Direct (unpooled) Postgres connection for the worker (checkpoints, queue,
# migrations). Falls back to DATABASE_URL_UNPOOLED then DATABASE_URL.
FACTORY_DATABASE_URL=
# Optional: force SSL even when the URL does not advertise it.
# PGSSL=require

# --- Environment identity (ADR 0014, parameters §9) -------------------------
# Declared environment id. Must match the factory.environment_identity marker
# row; any mismatch fails closed and blocks run creation.
FACTORY_ENV_ID=factory-dev

# --- Web <-> worker boundary (ADR 0015/0016) --------------------------------
# Shared HMAC secret for signed start/status/judgement/cancel requests.
FACTORY_SIGNING_SECRET=
# Worker base URL as seen from the web app (server side).
FACTORY_WORKER_URL=http://localhost:8787
# Worker base URL as seen from the browser (SSE); often the same.
NEXT_PUBLIC_FACTORY_WORKER_URL=http://localhost:8787

# --- Model mode -------------------------------------------------------------
# "mock" = deterministic fixtures, zero model calls; "live" = real Anthropic.
FACTORY_MODEL_MODE=mock
# Live runs additionally require ANTHROPIC_API_KEY (usually inherited from
# ../web/.env.local).
# ANTHROPIC_API_KEY=

# --- Presenter route (ADR 0013) ---------------------------------------------
CF_PRESENTER_CODE=
CF_PRESENTER_SPEND_CEILING_USD=35
